{% if template contains 'index' or  template contains 'collection' or template contains 'product' %}
<script type="text/javascript">
        var wpErrors = [];

        window.onerror = function(error, url, line) {
            wpErrors.push({
                errorMessage : error,
                lineNumber : line
            });
        };
    </script>
