        "faq_PCfkDh": {
          "type": "faq",
          "settings": {
            "question": "What is Island Way Sorbet?",
            "answer": "<p>Island Way sorbet is a premium, all-natural fruit sorbet with a touch of cream served in real fruit shells such as coconut, orange, pineapple, and more. It’s a refreshing dessert perfect for any occasion.</p>"
          }
        },
        "faq_XBnDhn": {
          "type": "faq",
          "settings": {
            "question": "Are Island Way Sorbets dairy-free?",
            "answer": "<p>Our sorbets contain dairy. We start with a traditional sorbet recipe that’s gluten-free and cholesterol-free, making them a refreshing choice for a variety of dietary lifestyles.</p>"
          }
        },
        "faq_zN7DrC": {
          "type": "faq",
          "settings": {
            "question": "Do you offer dairy-free flavors?",
            "answer": "<p>Yes. Our Tropical Mango flavor is dairy-free. You can find it in single-flavor packs and as part of our variety pack assortments.<br/><br/><br/></p>"
          }
        },
        "faq_9w794g": {
          "type": "faq",
          "settings": {
            "question": "Do Island Way products contain allergens?",
            "answer": "<p>Island Way sorbets contain milk. Please read the ingredient statement carefully on the back of each product if you have any allergen concerns. For specific questions about a product or the facility in which it was produced, please contact our Customer Care team at <a href=\"mailto:info@islandway.com\">info@islandway.com</a>.</p>"
          }
        },
        "faq_jc7i6p": {
          "type": "faq",
          "settings": {
            "question": "Is Island Way gluten-free?",
            "answer": "<p>Yes. All Island Way products are certified gluten-free by the GFCO. Please read the ingredient statement carefully on the back of each product if you have any allergen concerns.<br/></p>"
          }
        },
        "faq_JbreWB": {
          "type": "faq",
          "settings": {
            "question": "Is Island Way kosher?",
            "answer": "<p>Yes. All products are certified kosher by the Orthodox Union. Our sorbets are OU-D certified.<br/></p>"
          }
        },
        "faq_yaTUeK": {
          "type": "faq",
          "settings": {
            "question": "Is Island Way non-GMO?",
            "answer": "<p>Yes. Island Way uses non-GMO ingredients.<br/></p>"
          }
        },
        "faq_PPHHHp": {
          "type": "faq",
          "settings": {
            "question": "Do Island Way sorbets use milk that is free of added hormones and antibiotics?",
            "answer": "<p>Yes. We use rBST-free milk and cream in products that contain dairy.<br/><br/></p>"
          }
        },
        "faq_F4cMG7": {
          "type": "faq",
          "settings": {
            "question": "Does Island Way contain nuts?",
            "answer": "<p>No. Island Way products are nut-free. Nuts are not present in our facility, as we do not manufacture any products that contain nuts. Please read the ingredient statement carefully on the back of each product if you have any allergen concerns.</p>"
          }
        },
        "faq_km7nz7": {
          "type": "faq",
          "settings": {
            "question": "Can I recycle your packaging?",
            "answer": "<p>Yes. Island Way cartons and plastic films are recyclable. The real fruit shells are compostable.</p>"
          }
        },
        "faq_dAAUYb": {
          "type": "faq",
          "settings": {
            "question": "How should I store Island Way Sorbet?",
            "answer": "<p>Keep sorbets frozen at all times until ready to serve. Store at 0°F (-18°C) or below for best quality.</p>"
          }
        },
        "faq_hQGMpw": {
          "type": "faq",
          "settings": {
            "question": "Do I need to thaw before eating?",
            "answer": "<p>For the best texture and flavor, allow sorbets to thaw for 2–3 minutes at room temperature before enjoying.</p>"
          }
        },
        "faq_iDn8gB": {
          "type": "faq",
          "settings": {
            "question": "Can I eat the fruit shell?",
            "answer": "<p>No. While technically edible, the shell is mostly decorative and not intended to be eaten. Most people choose to discard it.</p>"
          }
        },
        "faq_NgJJak": {
          "type": "faq",
          "settings": {
            "question": "Where can I buy Island Way Sorbet?",
            "answer": "<p>You can find Island Way Sorbet at select grocery stores, wholesale clubs, restaurants, and resorts across the U.S. and internationally. Availability varies by region.</p>"
