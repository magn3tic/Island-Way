    "page_builder_story_hAWrkq": {
      "type": "page-builder-story",
      "name": "Story Section",
      "settings": {
        "left_title": "Our Story",
        "left_heading": "AN ODE TO NATURE'S PERFECT PACKAGING",
        "description": "<p>Island Way began as a way to share the most mouthwatering sorbet while letting you savor a taste of palm-shaded paradise. </p><p>As we turned tropical fruits into frozen treats, we took our cue from nature’s perfect packaging, the natural fruit shell.</p><p>Encased in real husks and peels, every serving is portion-perfect, biodegradable, and naturally beautiful, giving you that straight-from-the-island, immersive everyday escape with less waste.</p>",
        "icon_image": "shopify://shop_images/blue-star.webp",
        "main_image": "shopify://shop_images/story-main.webp"
      }
    },
    "page_builder_welcome_FpTxNq": {
      "type": "page-builder-welcome",
      "blocks": {
        "about_mqM7jC": {
          "type": "about",
          "settings": {
            "about_image": "shopify://shop_images/celebration.webp",
            "about_subheading": "The Island Way",
            "about_heading": "WELCOME TO THE ISLAND",
            "about_text": "<p>Island Way fruits are hand-picked, hand-carved, and hand-crafted into our sorbet.</p><p>Each fruit is harvested at peak freshness from local fields and orchards, precisely sliced, scooped and flash-frozen to preserve nature’s perfect design. All our sorbets are crafted from the finest non-GMO ingredients, in a world-class facility, by highly skilled confectioners who maintain exceptional standards for quality and safety.</p><p>No preservatives, no artificial flavors, no artificial colors. Just natural sweetness and a blissful break for the islands.</p>"
          }
        },
