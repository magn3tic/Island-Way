<!-- Banner Start -->
<section class="banner-area product-banner">
  {% if section.settings.bg_image != blank %}
    <img class="product-banner-bg" src="{{ section.settings.bg_image | image_url: width: 2000 }}" alt="{{ section.settings.heading | escape }}">
  {% endif %}

  <div class="container">
    <div class="banner-text text-center">
      {% if section.settings.heading != blank %}
        <h1 class="heading">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="cta-btn btn_orange">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    {% if section.settings.enable_shapes %}
      {% if section.settings.shape_cream != blank %}
        <span class="banner-item-cream banner-shape">
          <img src="{{ section.settings.shape_cream | image_url: width: 400 }}" alt="Cream shape">
        </span>
      {% endif %}
      {% if section.settings.shape_berry != blank %}
        <span class="banner-item-berry banner-shape">
          <img src="{{ section.settings.shape_berry | image_url: width: 400 }}" alt="Berry shape">
        </span>
      {% endif %}
      {% if section.settings.shape_orange != blank %}
        <span class="banner-item-orange banner-shape">
          <img src="{{ section.settings.shape_orange | image_url: width: 400 }}" alt="Orange shape">
        </span>
      {% endif %}
      {% if section.settings.shape_coconut != blank %}
        <span class="banner-item-coconut banner-shape">
          <img src="{{ section.settings.shape_coconut | image_url: width: 400 }}" alt="Coconut shape">
        </span>
      {% endif %}
    {% endif %}
  </div>

    <span class="banner-palm-left"><img src="https://cdn.shopify.com/s/files/1/0732/7829/2203/files/p-banner-left.webp" alt="image"></span>
    <span class="banner-palm-right"><img src="https://cdn.shopify.com/s/files/1/0732/7829/2203/files/p-banner-lright.webp" alt="image"></span>
</section>
<!-- Banner End -->

{% schema %}
{
  "name": "Product Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PARADISE IN<br>EVERY BITE"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Explore Flavors"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "checkbox",
      "id": "enable_shapes",
      "label": "Enable Fruit Shapes",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "shape_cream",
      "label": "Cream Shape"
    },
    {
      "type": "image_picker",
      "id": "shape_berry",
      "label": "Berry Shape"
    },
    {
      "type": "image_picker",
      "id": "shape_orange",
      "label": "Orange Shape"
    },
    {
      "type": "image_picker",
      "id": "shape_coconut",
      "label": "Coconut Shape"
    }    
  ],
  "presets": [
    {
      "name": "Product Banner"
    }
  ]
}
{% endschema %}