<section class="content-area bg_brown story-area">
  <div class="container">
    <div class="content-text story-content">
      <div class="row align-items-lg-end">

        {% if section.settings.left_title != blank or section.settings.left_heading != blank %}
        <div class="col-lg-5 col-sm-6">
          <div class="section-heading">
            {% if section.settings.left_title != blank %}
              <span class="title">{{ section.settings.left_title }}</span>
            {% endif %}
            {% if section.settings.left_heading != blank %}
              <h2 class="heading">{{ section.settings.left_heading }}</h2>
            {% endif %}
          </div>
        </div>
        {% endif %}

        <div class="col-lg-6 col-sm-6 ms-auto">
          <div class="content-text">
            {% if section.settings.icon_image != blank %}
              <img src="{{ section.settings.icon_image | image_url }}" alt="icon">
            {% endif %}
            {% if section.settings.description != blank %}
              {{ section.settings.description }}
            {% endif %}            
          </div>
        </div>

        {% if section.settings.main_image != blank %}
        <div class="col-lg-12">
          <div class="image-box story-image">
            <img src="{{ section.settings.main_image | image_url: width: 1200 }}" alt="story image">
          </div>
        </div>
        {% endif %}

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Story Section",
  "settings": [
    {
      "type": "text",
      "id": "left_title",
      "label": "Tagline",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "left_heading",
      "label": "Heading",
      "default": "AN ODE TO NATURE'S PERFECT PACKAGING"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },    
    {
      "type": "image_picker",
      "id": "icon_image",
      "label": "Blue Star Icon"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Story Image"
    }
  ],
  "presets": [
    {
      "name": "Story Section"
    }
  ]
}
{% endschema %}