<section class="content-area bg_brown story-area">
  <div class="container">
    <div class="content-text story-content">
      <div class="row align-items-lg-end">
        {% if section.settings.left_title != blank or section.settings.left_heading != blank %}
        <div class="col-lg-5 col-sm-6">
          <div class="section-heading">
            {% if section.settings.left_title != blank %}
              <span class="title">{{ section.settings.left_title }}</span>
            {% endif %}
            {% if section.settings.left_heading != blank %}
              <h2 class="heading">{{ section.settings.left_heading }}</h2>
            {% endif %}
          </div>
        </div>
        {% endif %}
        <div class="col-lg-6 col-sm-6 ms-auto">
          <div class="content-text">
            {% if section.settings.icon_image != blank %} 
              <img
                src="{{ section.settings.icon_image | image_url }}"
                alt="Island Way icon"
                width="{{ section.settings.icon_image.width }}"
                height="{{ section.settings.icon_image.height }}"
                loading="lazy"
                decoding="async"
              >
            {% endif %}
            {% if section.settings.description != blank %}
              {{ section.settings.description }}
            {% endif %}            
          </div>
        </div>
        {% if section.settings.main_image != blank %}
        <div class="col-lg-12">
          <div class="image-box story-image">
            <img
              src="{{ section.settings.main_image | image_url: width: 1200, format: 'webp' }}"
              srcset="
                {{ section.settings.main_image | image_url: width: 400,  format: 'webp' }}  400w,
                {{ section.settings.main_image | image_url: width: 600,  format: 'webp' }}  600w,
                {{ section.settings.main_image | image_url: width: 800,  format: 'webp' }}  800w,
                {{ section.settings.main_image | image_url: width: 1000, format: 'webp' }} 1000w,
                {{ section.settings.main_image | image_url: width: 1200, format: 'webp' }} 1200w
              "
              sizes="
                (max-width: 480px) 100vw,
                (max-width: 768px) 100vw,
                (max-width: 1024px) 80vw,
                1200px
              "
              alt="{{ section.settings.main_image.alt | default: 'Island Ways Story' }}"
              width="{{ section.settings.main_image.width }}"
              height="{{ section.settings.main_image.height }}"
              loading="lazy"
              decoding="async"
            >
          </div>
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Story Section",
  "settings": [
    {
      "type": "text",
      "id": "left_title",
      "label": "Tagline",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "left_heading",
      "label": "Heading",
      "default": "AN ODE TO NATURE'S PERFECT PACKAGING"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },    
    {
      "type": "image_picker",
      "id": "icon_image",
      "label": "Blue Star Icon"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Story Image"
    }
  ],
  "presets": [
    {
      "name": "Story Section"
    }
  ]
}
{% endschema %}