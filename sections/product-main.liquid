<section class="content-area product-details bg_brown pb-0">
  {% if product %}
    <img data-wpsob="1" data-wpsob-height="1" height="1" data-wpsob-width="1" width="1" data-wpsob-lazy="1" loading="lazy" class="product-details-shape" src="https://cdn.shopify.com/s/files/1/0732/7829/2203/files/product-details-palm.webp" alt="image">

    <div class="container">
      <div class="row">
        <div class="col-lg-5 col-sm-6">
          <div class="pr-slide-box">
            <span class="palm-shape">
              <img data-wpsob="1" data-wpsob-height="1" height="1" data-wpsob-width="1" width="1" data-wpsob-lazy="1" loading="lazy" src="https://cdn.shopify.com/s/files/1/0732/7829/2203/files/palm-shape.webp" alt="palm shape">
            </span>

            {% assign meta_featured = product.metafields.custom.custom_featured_image %}

            <!-- Main Slider -->
            <div class="product-details-slider">
              {% if meta_featured != blank %}
                <div class="slide">
                  <div class="image-box">
                    <img data-wpsob="1" data-wpsob-height="1" height="1" data-wpsob-width="1" width="1" data-wpsob-lazy="1" loading="lazy" 
                      src="{{ meta_featured | image_url: width: 800 }}" 
                      alt="{{ product.title }} (Featured Image)">
                  </div>
                </div>
              {% endif %}

              {% for media in product.media %}
                <div class="slide">
                  <div class="image-box">
                    {{ media | image_url: width: 800 | image_tag: alt: product.title }}
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>

          <!-- Thumbnail Navigation -->
          <div class="product-details-slider-nav">
            {% if meta_featured != blank %}
              <div class="slide">
                <div class="thumb-box">
                  <img data-wpsob="1" data-wpsob-height="1" height="1" data-wpsob-width="1" width="1" data-wpsob-lazy="1" loading="lazy" 
                    src="{{ meta_featured | image_url: width: 200 }}" 
                    alt="{{ product.title }} (Featured Image Thumbnail)">
                </div>
              </div>
            {% endif %}

            {% for media in product.media %}
              <div class="slide">
                <div class="thumb-box">
                  {{ media | image_url: width: 200 | image_tag: alt: product.title }}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>

        <!-- Product Info -->
        <div class="col-lg-6 col-sm-6 ms-auto">
          <div class="content-text product-info">
            <div class="review-text">
              <div class="review-stars"></div>
              {% if product.metafields.custom.availability != blank %}
                <span>{{ product.metafields.custom.availability }}</span>
              {% endif %}              
            </div>

            <script>
              document.addEventListener("DOMContentLoaded", () => {
                const jdgmBadge = document.querySelector(".jdgm-widget.jdgm-preview-badge");
                const reviewStars = document.querySelector(".review-stars");

                if (jdgmBadge && reviewStars) {
                  reviewStars.appendChild(jdgmBadge);
                }
              });
            </script>

            <h2 class="heading">{{ product.title }}</h2>

            {% assign availability_text = product.metafields.custom.availability.value | default: '' %}
            {% if availability_text == 'Available Online' %}

            {% if product.price %}
              <div class="price-action">
                <span class="price" id="product-price">{{ product.price | money }}</span>
                <ul>
                  {% for variant in product.variants %}
                    <li>
                      <input
                        type="radio"
                        name="variant"
                        id="variant-{{ variant.id }}"
                        value="{{ variant.id }}"
                        data-price="{{ variant.price | money }}"
                        {% if forloop.first %}checked{% endif %}
                      >
                      <label for="variant-{{ variant.id }}">{{ variant.title }}</label>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}

            {% endif %}

            {% assign availability_text = product.metafields.custom.availability.value | default: '' %}
            {% if availability_text == 'Available Online' %}

            <div class="product-details-action">
              <form method="post" action="/cart/add" id="add-to-cart-form">
                <input type="hidden" name="id" id="selected-variant" value="{{ product.variants.first.id }}">
                <button type="submit" class="btn-atc cta-btn btn_blue">ADD TO CART</button>
              </form>
            </div>

            {% else %}
            <div class="product-details-action">
              <a href="/pages/stores" class="cta-btn btn_blue">Find Near Me</a>
            </div>
            {% endif %}

            <script>
            document.addEventListener("DOMContentLoaded", function() {
              const variantRadios = document.querySelectorAll('input[name="variant"]');
              const variantInput = document.getElementById("selected-variant");
              const priceDisplay = document.getElementById("product-price");

              variantRadios.forEach(radio => {
                radio.addEventListener("change", function() {
                  variantInput.value = this.value; // update hidden input
                  if (priceDisplay && this.dataset.price) {
                    priceDisplay.textContent = this.dataset.price; // update price visually
                  }
                });
              });
            });
            </script>

            {% if product.description != blank %}
              <div class="mt-4">{{ product.description }}</div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</section>

<section class="content-area bg_brown">
  <div class="container">

    <!-- Desktop Tabs -->
    <div class="location-tab d-none d-md-block px-lg-5">
      <div class="tabs_wrapper">
