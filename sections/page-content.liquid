<section class="image-text-alt-section">
  <div class="container">
    {% if section.settings.section_heading != blank %}
      <div class="section-heading text-center mb-5">
        <h2 class="heading">{{ section.settings.section_heading }}</h2>
      </div>
    {% endif %}

    {% for block in section.blocks %}
      {% assign position_class = forloop.index | modulo: 2 | plus: 1 %}
      <div class="image-text-alt-row d-flex align-items-center flex-wrap {% if position_class == 1 %}image-left{% else %}image-right{% endif %}" {{ block.shopify_attributes }}>
        <div class="col-image col-md-6">
          {% if block.settings.image %}
            <div class="image-box">
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.heading | escape }}">
            </div>
          {% endif %}
        </div>

        <div class="col-content col-md-6">
          <div class="content-box">
            {% if block.settings.heading != blank %}
              <h3 class="block-heading">{{ block.settings.heading }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <div class="block-text">{{ block.settings.text }}</div>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Page Content",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "Our Story"
    }
  ],
  "blocks": [
    {
      "type": "image_text_block",
      "name": "Image + Text Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading here"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add your content here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Page Content"
    }
  ]
}
{% endschema %}