<!-- Collections List Section -->
<section class="content-area bg_blue collection-header">
  <div class="container">

    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="section-heading text-center">
        {% if section.settings.heading != blank %}
          <h2 class="heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p>{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

<section class="content-area collection-list">
  <div class="container">

    {% assign collections_to_show = collections | sort: 'title' %}
    {% if section.settings.limit > 0 %}
      {% assign collections_to_show = collections_to_show | slice: 0, section.settings.limit %}
    {% endif %}

    <div class="row">
      {% for collection in collections_to_show %}
        {% if collection.all_products_count > 0 %}
          {% assign fallback_image = blank %}
          {% if collection.image %}
            {% assign fallback_image = collection.image %}
          {% elsif collection.products.first.featured_image %}
            {% assign fallback_image = collection.products.first.featured_image %}
          {% endif %}

          <div class="col-lg-4 col-sm-6 mb-4">
            <a href="{{ collection.url }}" class="product-box collection-box">
                <div class="image-box">
                {% if fallback_image %}
                    <img
                      src="{{ fallback_image | image_url: width: 600 }}"
                      alt="{{ collection.title | escape }}"
                      class="img-fluid"
                      loading="lazy"
                    >
                  {% else %}
                    {{ 'collection-1' | placeholder_svg_tag: 'img-fluid' }}
                  {% endif %}
                </div>
                <div class="text-box">
                    <h3 class="title">{{ collection.title }}</h3>
                </div>
            </a>            
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Collections List",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore our full range of collections"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Number of Collections to Show",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 0,
      "info": "Set to 0 to show all collections."
    }
  ],
  "presets": [
    {
      "name": "Collections List"
    }
  ]
}
{% endschema %}
